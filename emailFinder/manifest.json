{
  "manifest_version": 3,
  "version": "0.1.4",
  "name": "eMail Address Finder",
  "author": "makingStuffForFun",
  "description": "Extract and manage email addresses from messages with smart filtering",
  "browser_specific_settings": {
    "gecko": {
      "id": "emailFinder@accessibility.extensions.makingStuffForFun.net",
      "strict_min_version": "128.0"
    }
  },
  "permissions": [
    "messagesRead",
    "menus",
    "storage"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "compose_action": {
    "type": "menu",
    "default_title": "eMail Address Finder",
    "theme_icons": [
      {
        "dark": "images/emailFinder_16x.png",
        "light": "images/emailFinder_16x_white.png",
        "size": 16
      },
      {
        "dark": "images/emailFinder_32x.png",
        "light": "images/emailFinder_32x_white.png",
        "size": 32
      },
      {
        "dark": "images/emailFinder_64x.png",
        "light": "images/emailFinder_64x_white.png",
        "size": 64
      },
      {
        "dark": "images/emailFinder_128x.png",
        "light": "images/emailFinder_128x_white.png",
        "size": 128
      }
    ]
  },
  "message_display_action": {
    "type": "menu",
    "default_title": "eMail Address Finder",
    "theme_icons": [
      {
        "dark": "images/emailFinder_16x.png",
        "light": "images/emailFinder_16x_white.png",
        "size": 16
      },
      {
        "dark": "images/emailFinder_32x.png",
        "light": "images/emailFinder_32x_white.png",
        "size": 32
      },
      {
        "dark": "images/emailFinder_64x.png",
        "light": "images/emailFinder_64x_white.png",
        "size": 64
      },
      {
        "dark": "images/emailFinder_128x.png",
        "light": "images/emailFinder_128x_white.png",
        "size": 128
      }
    ]
  },
  "options_ui": {
    "page": "options.html"
  }
}
